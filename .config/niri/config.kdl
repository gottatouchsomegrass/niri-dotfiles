// ==================================================
// Recent Windows
// ==================================================

recent-windows {
    debounce-ms 500
    open-delay-ms 100

    highlight {
        active-color "#8aadf4ff"
        urgent-color "#ed8796ff"
        padding 8
        corner-radius 4
    }

    previews {
        max-height 500
        max-scale 0.5
    }
    binds {
        Alt+Tab         { next-window     scope="workspace"; }
        Alt+Shift+Tab   { previous-window scope="workspace"; }
    }
}


// ==================================================
// fixed workspaces
// ==================================================

workspace "1"
workspace "2"

