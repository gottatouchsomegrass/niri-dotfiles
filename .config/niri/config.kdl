    match app-id="org.gnome.Nautilus"
    //open-floating true
    // default-column-width { }
    //default-window-height { fixed 500; }
    opacity 0.75
    draw-border-with-background false
    background-effect {
        xray true
        blur true
        //noise 0.05
        //saturation 3
    }
    popups {
        opacity 0.9
    }
}

